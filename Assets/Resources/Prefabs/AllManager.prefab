  ArmorInfoPackList:
  - armorType: 1
    armorName: "\u9646\u519B\u5957\u88C5"
    armorDescription: "\u5236\u9020\u516C\u53F8\uFF1A\u5317\u5883\u91CD\u5DE5\u96C6\u56E2\n\u5236\u9020\u65F6\u95F4\uFF1A2024
      \u5E74\n\u91C7\u7528\u590D\u5408\u9676\u74F7\u88C5\u7532\u6253\u9020\u7684\u91CD\u578B\u62A4\u7532\uFF0C\u4E13\u4E3A\u9635\u5730\u653B\u575A\u8BBE\u8BA1\uFF0C\u4EE5\u5B8C\u5168\u653E\u5F03\u673A\u52A8\u6027\u4E3A\u4EE3\u4EF7\uFF0C\u63D0\u4F9B
      50 \u70B9\u9AD8\u989D\u751F\u547D\u52A0\u6210\uFF0C\u662F\u524D\u7EBF\u625B\u4F24\u3001\u62B5\u5FA1\u706B\u529B\u7684\u79FB\u52A8\u5821\u5792\uFF0C\u80FD\u5728\u5BC6\u96C6\u4EA4\u706B\u4E2D\u4E3A\u7A7F\u6234\u8005\u7B51\u8D77\u7EDD\u5BF9\u751F\u5B58\u5C4F\u969C\u3002"
    HelmetSprite: {fileID: 1939655542, guid: 5be7f999a0d365240b9ba22b377fdffe, type: 3}
    ArmorSprite: {fileID: -2094236514, guid: 5be7f999a0d365240b9ba22b377fdffe, type: 3}
    UISprite: {fileID: 1906845293, guid: a900fae8d1623d04b8309f86363d8681, type: 3}
    HealthAdd: 50
    SpeedAdd: 0
  - armorType: 2
    armorName: "\u6D77\u519B\u5957\u88C5"
    armorDescription: "\u5236\u9020\u516C\u53F8\uFF1A\u5927\u897F\u6D0B\u6218\u672F\u5DE5\u4E1A\n\u5236\u9020\u65F6\u95F4\uFF1A2024
      \u5E74\n\u6A21\u5757\u5316\u4E24\u6816\u4F5C\u6218\u62A4\u7532\uFF0C\u517C\u987E\u9632\u62A4\u4E0E\u673A\u52A8\u6027\uFF0C\u63D0\u4F9B
      30 \u70B9\u751F\u547D\u52A0\u6210\u4E0E 0.5 \u79FB\u901F\u589E\u76CA\uFF0C\u9002\u914D\u6D77\u9646\u590D\u6742\u6218\u573A\u73AF\u5883\uFF0C\u65E2\u5177\u5907\u53EF\u9760\u6297\u4F24\u80FD\u529B\uFF0C\u53C8\u80FD\u4FDD\u8BC1\u6218\u672F\u8F6C\u79FB\u6548\u7387\uFF0C\u662F\u5168\u80FD\u578B\u4F5C\u6218\u5355\u4F4D\u7684\u4F18\u9009\u88C5\u5907\u3002"
    HelmetSprite: {fileID: 1346903642, guid: 5be7f999a0d365240b9ba22b377fdffe, type: 3}
    ArmorSprite: {fileID: -920568153, guid: 5be7f999a0d365240b9ba22b377fdffe, type: 3}
