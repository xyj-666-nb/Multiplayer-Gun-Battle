  - armorType: 3
    armorName: "\u7A7A\u519B\u5957\u88C5"
    armorDescription: "\u5236\u9020\u516C\u53F8\uFF1A\u7A7A\u901F\u822A\u7A7A\u79D1\u6280\n\u5236\u9020\u65F6\u95F4\uFF1A2024
      \u5E74\n\u8D85\u8F7B\u78B3\u7EA4\u7EF4\u7ED3\u6784\u7684\u7A81\u51FB\u62A4\u7532\uFF0C\u6781\u81F4\u5F3A\u5316\u673A\u52A8\u6027\uFF0C\u4EC5\u4FDD\u7559
